<?xml version="1.0" encoding="utf-8"?>
<!--
    OTT Application Manifest
    Registers MainActivity, SetupActivity, TvInputService and supporting components.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.ott"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="21"
        android:targetSdkVersion="35" />

    <!-- Network access for HLS streams and server JSON -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read channel/program data from TvProvider -->
    <uses-permission android:name="com.android.providers.tv.permission.READ_EPG_DATA" />
    <!-- Write channel/program data to TvProvider -->
    <uses-permission android:name="com.android.providers.tv.permission.WRITE_EPG_DATA" />
    <!-- Re-schedule EPG sync after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Android TV hardware requirements -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.software.live_tv"
        android:required="true" />

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <permission
        android:name="com.example.ott.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.ott.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="false"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:banner="@drawable/ic_banner"
        android:debuggable="true"
        android:extractNativeLibs="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:testOnly="true"
        android:theme="@style/Theme.Leanback" >

        <!--
             ================================================================
             MainActivity – Leanback launcher entry point (dummy splash)
             ================================================================
        -->
        <activity
            android:name="com.example.ott.MainActivity"
            android:exported="true"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
             ================================================================
             SetupActivity – launched by Live Channels before using the input
             ================================================================
        -->
        <activity
            android:name="com.example.ott.rich.OttSetupActivity"
            android:exported="true"
            android:label="@string/setup_title"
            android:theme="@style/Theme.Setup" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>

        <!--
             ================================================================
             OTT TV Input Service
             ================================================================
        -->
        <service
            android:name="com.example.ott.rich.OttTvInputService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_TV_INPUT" >
            <intent-filter>
                <action android:name="android.media.tv.TvInputService" />
            </intent-filter>
            <!-- Points Live Channels to SetupActivity -->
            <meta-data
                android:name="android.media.tv.input"
                android:resource="@xml/otttvinputservice" />
        </service>

        <!--
             ================================================================
             EPG sync job – runs periodically to refresh channel data
             ================================================================
        -->
        <service
            android:name="com.example.ott.rich.OttEpgJobService"
            android:exported="true"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <!--
             ================================================================
             Boot receiver – reschedules EPG sync after reboot
             ================================================================
        -->
        <receiver
            android:name="com.example.ott.rich.OttBootReceiver"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>